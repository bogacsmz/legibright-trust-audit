# Copy to .env and fill in. Local OSS DataHub quickstart defaults shown.

# DataHub GMS (metadata service). Quickstart default:
DATAHUB_GMS_URL=http://localhost:8080
# Personal access token — create in DataHub UI → Settings → Access Tokens.
# For fresh local quickstart with auth disabled, this can be left blank.
DATAHUB_GMS_TOKEN=

# MCP server toggles (passed through to `uvx mcp-server-datahub`)
TOOLS_IS_MUTATION_ENABLED=true
TOOLS_IS_USER_ENABLED=false

# Where the demo source dbs live (read-only; ingested into DataHub as metadata)
TJK_DB=/Users/bogacsasmaz/Claude/Projects/tjk-sib/tjk_sib.db
TR_ODDS_DB=/Users/bogacsasmaz/Claude/Projects/tr-spor-value/tr_odds.db
IDDAA_DB=/Users/bogacsasmaz/Claude/Projects/tr-spor-value/iddaa_snap.db
